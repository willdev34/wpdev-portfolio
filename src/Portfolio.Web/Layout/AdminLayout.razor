@* ====================================
   Título: AdminLayout.razor
   Descrição: Layout da área administrativa
   ==================================== *@

@inherits LayoutComponentBase
@using Portfolio.Web.Auth
@inject JwtAuthStateProvider AuthProvider
@inject NavigationManager Navigation

<div class="admin-shell">

    <!-- TOPBAR: só aparece em telas <= 768px -->
    <header class="admin-topbar">
        <a href="/admin" class="admin-topbar__brand">
            <img src="/images/wpdev-logo-header.webp" alt="WPDev" class="admin-logo" />
        </a>

        <button class="admin-nav-toggle" @onclick="ToggleSidebar"
                aria-label="@(sidebarOpen ? "Fechar menu" : "Abrir menu")"
                aria-expanded="@sidebarOpen">
            <span class="hb-line hb-line--top @(sidebarOpen ? "open" : "")"></span>
            <span class="hb-line hb-line--mid @(sidebarOpen ? "open" : "")"></span>
            <span class="hb-line hb-line--bot @(sidebarOpen ? "open" : "")"></span>
        </button>
    </header>

    <!-- OVERLAY: fecha o menu ao clicar fora (só ativo no mobile) -->
    <div class="admin-overlay @(sidebarOpen ? "admin-overlay--open" : "")"
         @onclick="CloseSidebar"
         aria-hidden="true">
    </div>

    <aside class="admin-sidebar @(sidebarOpen ? "admin-sidebar--open" : "")">
        <div class="admin-brand">
            <img src="/images/wpdev-logo-header.webp" alt="WPDev" class="admin-logo" />
            <span class="brand-label">Admin</span>
        </div>

        <nav class="admin-nav">
            <a class="admin-nav__item" href="/admin" @onclick="CloseSidebar">
                <span class="nav-icon">▦</span>
                Dashboard
            </a>
            <a class="admin-nav__item" href="/admin/projects" @onclick="CloseSidebar">
                <span class="nav-icon">◈</span>
                Projetos
            </a>
            <a class="admin-nav__item" href="/admin/blog" @onclick="CloseSidebar">
                <span class="nav-icon">✦</span>
                Blog
            </a>
            <a class="admin-nav__item" href="/admin/timeline" @onclick="CloseSidebar">
                <span class="nav-icon">◎</span>
                Timeline
            </a>
            <a class="admin-nav__item" href="/admin/now" @onclick="CloseSidebar">
                <span class="nav-icon">◉</span>
                Now
            </a>
            <a class="admin-nav__item" href="/admin/messages" @onclick="CloseSidebar">
                <span class="nav-icon">◻</span>
                Mensagens
            </a>
        </nav>

        <div class="admin-sidebar__footer">
            <a class="admin-nav__item" href="/" target="_blank">
                <span class="nav-icon">↗</span>
                Ver site
            </a>
            <button class="admin-logout" @onclick="Logout">
                <span class="nav-icon">⏻</span>
                Sair
            </button>
        </div>
    </aside>

    <main class="admin-main">
        <div class="admin-content">
            @Body
        </div>
    </main>
</div>

@code {
    private bool sidebarOpen = false;

    private void ToggleSidebar()
    {
        sidebarOpen = !sidebarOpen;
    }

    private void CloseSidebar()
    {
        sidebarOpen = false;
    }

    private async Task Logout()
    {
        await AuthProvider.RemoveTokenAsync();
        Navigation.NavigateTo("/admin/login");
    }
}