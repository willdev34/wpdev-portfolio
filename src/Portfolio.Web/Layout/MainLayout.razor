@* ====================================
   Título: MainLayout.razor
   Descrição: Layout principal do portfólio WPDev
   Nota: mobile-overlay e mobile-menu estão FORA do 
         wpdev-layout para evitar stacking context do header
   ==================================== *@

@inherits LayoutComponentBase

<div class="wpdev-layout">

    <!-- HEADER -->
    <header class="wpdev-header">
        <div class="container">
            <nav class="wpdev-nav">

                <!-- Logo -->
                <a href="/" class="brand-link">
                    <img src="/images/wpdev-logo-header.webp" alt="WPDev" class="brand-logo" />
                </a>

                <!-- Menu desktop: visível apenas em telas >= 769px -->
                <ul class="nav-menu-desktop">
                    <li><a href="/" class="nav-link">Home</a></li>
                    <li><a href="/projects" class="nav-link">Projetos</a></li>
                    <li><a href="/blog" class="nav-link">Blog</a></li>
                    <li><a href="/timeline" class="nav-link">Timeline</a></li>
                    <li><a href="/now" class="nav-link">Now</a></li>
                    <li><a href="/contact" class="nav-link">Contato</a></li>
                </ul>

                <!-- Botão hamburguer: visível apenas no mobile -->
                <button class="nav-toggle" @onclick="ToggleMenu"
                        aria-label="@(menuOpen ? "Fechar menu" : "Abrir menu")"
                        aria-expanded="@menuOpen">
                    <span class="hb-line hb-line--top @(menuOpen ? "open" : "")"></span>
                    <span class="hb-line hb-line--mid @(menuOpen ? "open" : "")"></span>
                    <span class="hb-line hb-line--bot @(menuOpen ? "open" : "")"></span>
                </button>

            </nav>
        </div>
    </header>

    <!-- CONTEÚDO PRINCIPAL -->
    <main class="wpdev-main">
        <ErrorBoundary @ref="errorBoundary">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="exception">
                <div class="error-container">
                    <h2>Algo deu errado por aqui</h2>
                    <p>Tente recarregar a página. Se o problema continuar, me avisa pelo contato.</p>
                    <button class="btn btn-primary" @onclick="RecoverError">Tentar novamente</button>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </main>

    <!-- FOOTER -->
    <footer class="wpdev-footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-left">
                    <p class="footer-brand">
                        <img src="/images/wpdev-logo.webp" alt="WPDev" class="brand-logo brand-logo--footer" />
                    </p>
                </div>
                <div class="footer-right">
                    <p>&copy; @DateTime.Now.Year WPDev. Todos os direitos reservados.</p>
                </div>
            </div>
        </div>
    </footer>

</div>

@* ===================================================
   MOBILE: Overlay e painel fora do wpdev-layout
   Isso é crítico para o position:fixed funcionar
   sem ser bloqueado pelo stacking context do header
   =================================================== *@

<div class="mobile-overlay @(menuOpen ? "mobile-overlay--open" : "")"
     @onclick="CloseMenu"
     aria-hidden="true">
</div>

<div class="mobile-menu @(menuOpen ? "mobile-menu--open" : "")"
     role="dialog"
     aria-modal="true"
     aria-label="Menu de navegação">

    <!-- Cabeçalho do painel mobile -->
    <div class="mobile-menu-header">
        <a href="/" class="brand-link" @onclick="CloseMenu">
            <img src="/images/wpdev-logo-header.webp" alt="WPDev" class="brand-logo" /> 
        </a>
        <button class="mobile-close-btn" @onclick="CloseMenu" aria-label="Fechar menu">
            <svg viewBox="0 0 24 24" width="20" height="20"
                 fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
    </div>

    <!-- Links de navegação com animação stagger -->
    <nav class="mobile-nav">
        <ul class="mobile-nav-list">
            <li class="mobile-nav-item">
                <a href="/" class="mobile-nav-link" @onclick="CloseMenu">Home</a>
            </li>
            <li class="mobile-nav-item">
                <a href="/projects" class="mobile-nav-link" @onclick="CloseMenu">Projetos</a>
            </li>
            <li class="mobile-nav-item">
                <a href="/blog" class="mobile-nav-link" @onclick="CloseMenu">Blog</a>
            </li>
            <li class="mobile-nav-item">
                <a href="/timeline" class="mobile-nav-link" @onclick="CloseMenu">Timeline</a>
            </li>
            <li class="mobile-nav-item">
                <a href="/now" class="mobile-nav-link" @onclick="CloseMenu">Now</a>
            </li>
            <li class="mobile-nav-item">
                <a href="/contact" class="mobile-nav-link" @onclick="CloseMenu">Contato</a>
            </li>
        </ul>
    </nav>

    <div class="mobile-menu-footer">
        <p>&copy; @DateTime.Now.Year WPDev</p>
    </div>

</div>

@* @code SEMPRE no final do arquivo *@
@code {
    private ErrorBoundary? errorBoundary;
    private bool menuOpen = false;

    protected override void OnParametersSet()
    {
        errorBoundary?.Recover();
    }

    private void RecoverError()
    {
        errorBoundary?.Recover();
    }

    private void ToggleMenu()
    {
        menuOpen = !menuOpen;
    }

    private void CloseMenu()
    {
        menuOpen = false;
    }
}