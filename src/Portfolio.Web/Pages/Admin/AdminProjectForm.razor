@* ====================================
   Título: AdminProjectForm.razor
   Descrição: Formulário de criação e edição de projetos
   ==================================== *@

@page "/admin/projects/new"
@page "/admin/projects/edit/{Id:guid}"
@layout Portfolio.Web.Layout.AdminLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ProjectService ProjectService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@(_isEdit ? "Editar Projeto" : "Novo Projeto") - WPDev Admin</PageTitle>

<div class="admin-page">
    <div class="admin-page__header">
        <div>
            <a class="back-link" href="/admin/projects">← Projetos</a>
            <h1 class="admin-page__title">@(_isEdit ? "Editar Projeto" : "Novo Projeto")</h1>
        </div>
    </div>

    @if (_isLoading)
    {
        <p class="admin-loading">Carregando...</p>
    }
    else
    {

        <div class="form-grid">
            <div class="form-section">
                <h2 class="form-section__title">Informações Principais</h2>

                <div class="field">
                    <label class="field__label">Título *</label>
                    <input class="field__input" @bind="_form.Title" placeholder="Nome do projeto" />
                </div>

                <div class="field">
                    <label class="field__label">Descrição curta</label>
                    <input class="field__input" @bind="_form.ShortDescription" placeholder="Resumo em uma linha" />
                </div>

                <div class="field">
                    <label class="field__label">Descrição completa *</label>
                    <textarea class="field__textarea" @bind="_form.Description" placeholder="Descreva o projeto em detalhes" rows="5"></textarea>
                </div>

                <div class="field-row">
                    <div class="field">
                        <label class="field__label">Ano *</label>
                        <input class="field__input" type="number" @bind="_form.Year" />
                    </div>
                    <div class="field">
                        <label class="field__label">Status</label>
                        <select class="field__select" @bind="_form.Status">
                            <option value="0">Planejamento</option>
                            <option value="1">Em andamento</option>
                            <option value="2">Concluído</option>
                            <option value="3">Arquivado</option>
                        </select>
                    </div>
                </div>

                <div class="field field--checkbox">
                    <input type="checkbox" id="featured" @bind="_form.IsFeatured" />
                    <label for="featured">Projeto em destaque</label>
                </div>
            </div>

            <div class="form-section">
                <h2 class="form-section__title">Links e Mídia</h2>

                <div class="field">
                    <label class="field__label">Imagem *</label>
                    <ImageUpload CurrentUrl="@_form.ImageUrl"
                                OnUrlChanged="@OnImageUrlChanged" />
                </div>

                <div class="field">
                    <label class="field__label">URL do demo</label>
                    <input class="field__input" @bind="_form.DemoUrl" placeholder="https://..." />
                </div>

                <div class="field">
                    <label class="field__label">URL do repositório</label>
                    <input class="field__input" @bind="_form.RepositoryUrl" placeholder="https://github.com/..." />
                </div>

                <div class="field">
                    <label class="field__label">Tecnologias</label>
                    <div class="tech-input-row">
                        <input class="field__input" @bind="_newTech" @onkeydown="HandleTechKeyDown" placeholder="Ex: .NET, React..." />
                        <button class="btn-add-tech" type="button" @onclick="AddTech">+</button>
                    </div>
                    <div class="tech-tags">
                        @foreach (var tech in _form.Technologies)
                        {
                            <span class="tech-tag">
                                @tech
                                <button type="button" @onclick="() => RemoveTech(tech)">×</button>
                            </span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="form-actions-wrapper">
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="form-error">@_errorMessage</div>
            }
            @if (!string.IsNullOrEmpty(_successMessage))
            {
                <div class="form-success">@_successMessage</div>
            }
            <div class="form-actions">
                <a class="btn-cancel" href="/admin/projects">Cancelar</a>
                <button class="btn-save" @onclick="HandleSubmit" disabled="@_isSaving">
                    @(_isSaving ? "Salvando..." : "Salvar projeto")
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool _isEdit => Id.HasValue;
    private bool _isLoading = true;
    private bool _isSaving = false;
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;
    private string _newTech = string.Empty;

    private CreateProjectDto _form = new();

    protected override async Task OnInitializedAsync()
    {
        if (_isEdit)
        {
            var project = await ProjectService.GetByIdAsync(Id!.Value);

            // Projeto não encontrado: redireciona sem mensagem
            if (project is null)
            {
                await JS.InvokeVoidAsync("eval", "window.location.href='/admin/projects'");
                return;
            }

            _form = new CreateProjectDto
            {
                Title = project.Title,
                Description = project.Description,
                ShortDescription = project.ShortDescription,
                ImageUrl = project.ImageUrl,
                DemoUrl = project.DemoUrl,
                RepositoryUrl = project.RepositoryUrl,
                Technologies = new List<string>(project.Technologies),
                Year = project.Year,
                IsFeatured = project.IsFeatured
            };
        }

        _isLoading = false;
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(_form.Title) ||
            string.IsNullOrWhiteSpace(_form.Description) ||
            string.IsNullOrWhiteSpace(_form.ImageUrl))
        {
            _errorMessage = "Título, descrição e URL da imagem são obrigatórios.";
            return;
        }

        _isSaving = true;
        _errorMessage = string.Empty;

        if (_isEdit)
        {
            var updateDto = new UpdateProjectDto
            {
                Id = Id!.Value,
                Title = _form.Title,
                Description = _form.Description,
                ShortDescription = _form.ShortDescription,
                ImageUrl = _form.ImageUrl,
                DemoUrl = _form.DemoUrl,
                RepositoryUrl = _form.RepositoryUrl,
                Technologies = _form.Technologies,
                Year = _form.Year,
                IsFeatured = _form.IsFeatured,
                Status = _form.Status,
                IsActive = true
            };

            var (success, error) = await ProjectService.UpdateAsync(updateDto);

            if (!success)
            {
                _errorMessage = error ?? "Erro ao atualizar projeto.";
                _isSaving = false;
                return;
            }
        }
        else
        {
            var (success, error) = await ProjectService.CreateAsync(_form);

            if (!success)
            {
                _errorMessage = error ?? "Erro ao criar projeto.";
                _isSaving = false;
                return;
            }
        }

        // Mostra mensagem de sucesso, aguarda e redireciona
       _successMessage = _isEdit ? "Projeto atualizado com sucesso." : "Projeto criado com sucesso.";
       _isSaving = false;
       await InvokeAsync(StateHasChanged);
       await Task.Delay(100);
       await InvokeAsync(StateHasChanged);
       await Task.Delay(5000);
       await JS.InvokeVoidAsync("eval", "window.location.href='/admin/projects'");
    }

    private void AddTech()
    {
        var tech = _newTech.Trim();
        if (!string.IsNullOrWhiteSpace(tech) && !_form.Technologies.Contains(tech))
            _form.Technologies.Add(tech);
        _newTech = string.Empty;
    }

    private async Task HandleTechKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddTech();
        await Task.CompletedTask;
    }

    private void RemoveTech(string tech)
    {
        _form.Technologies.Remove(tech);
    }

    private Task OnImageUrlChanged(string url)
    {
        _form.ImageUrl = url;
        Console.WriteLine($"[AdminProjectForm] ImageUrl atualizado: {url}");
        return Task.CompletedTask;
    }
}