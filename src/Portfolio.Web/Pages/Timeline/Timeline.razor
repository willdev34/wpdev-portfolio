@page "/timeline"
@using Portfolio.Web.Services
@using Portfolio.Web.DTOs.Timeline
@inject TimelineService TimelineService

<PageTitle>Timeline - WPDev Portfolio</PageTitle>

<div class="timeline-page">

    <!-- Hero Section -->
    <section class="timeline-hero">
        <h1 class="hero-title">Timeline</h1>
        <p class="hero-description">
            Minha jornada profissional em desenvolvimento,
            marcos importantes e evolução de carreira.
        </p>
    </section>

    <!-- Timeline Section -->
    <section class="timeline-section">

        @if (isLoading)
        {
            <div style="display: flex; flex-direction: column; gap: 24px;">
                @for (int i = 0; i < 4; i++)
                {
                    <LoadingSkeleton Variant="SkeletonVariant.Card" />
                }
            </div>
        }
        else if (!events.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">🗓️</div>
                <h3>Timeline em construção</h3>
                <p>Em breve a timeline profissional estará disponível.</p>
            </div>
        }
        else
        {
            <div class="timeline-container">
                @foreach (var evt in events.OrderByDescending(e => e.StartDate))
                {
                    <div class="timeline-item">

                        <!-- Marker -->
                        <div class="timeline-marker">
                            <div class="marker-dot @(evt.IsCurrent ? "marker-current" : "")"></div>
                        </div>

                        <!-- Date -->
                        <div class="timeline-date">
                            <span>@evt.StartDate.ToString("MMM yyyy")</span>
                            @if (evt.IsCurrent)
                            {
                                <span class="date-separator">→</span>
                                <span class="date-current">Atual</span>
                            }
                            else if (evt.EndDate.HasValue)
                            {
                                <span class="date-separator">→</span>
                                <span>@evt.EndDate.Value.ToString("MMM yyyy")</span>
                            }
                        </div>

                        <!-- Card -->
                        <div class="timeline-card">
                            @if (!string.IsNullOrEmpty(evt.IconUrl))
                            {
                                <div class="card-icon">
                                    <img src="@evt.IconUrl" alt="@evt.Company" />
                                </div>
                            }
                            <div class="card-content">
                                <h3 class="card-title">@evt.Title</h3>
                                <p class="card-company">@evt.Company</p>
                                <p class="card-description">@evt.Description</p>
                                @if (evt.IsCurrent)
                                {
                                    <span class="current-badge">✨ Posição Atual</span>
                                }
                            </div>
                        </div>

                    </div>
                }
            </div>
        }

    </section>

</div>

@code {
    private List<TimelineEventDto> events = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadTimeline();
    }

    private async Task LoadTimeline()
    {
        isLoading = true;
        StateHasChanged();
        try
        {
            events = await TimelineService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar timeline: {ex.Message}");
            events = new List<TimelineEventDto>();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}