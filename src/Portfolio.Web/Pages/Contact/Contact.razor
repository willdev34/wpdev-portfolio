@* ====================================
   Título: Contact.razor
   Descrição: Página de contato minimalista
   Refatorada: design editorial, SendContactMessageDto,
               estilos movidos para Contact.razor.css
   ==================================== *@

@page "/contact"
@using Portfolio.Web.Services
@using Portfolio.Web.DTOs.Contact
@inject ContactService ContactService

<PageTitle>Contato - WPDev</PageTitle>

<!-- PAGE HEADER -->
<section class="contact-header">
    <div class="container">
        <p class="contact-eyebrow">Vamos conversar</p>
        <h1 class="contact-title">
            Entre em<br />
            <span class="contact-title-accent">Contato</span>
        </h1>
        <p class="contact-subtitle">
            Tem um projeto em mente? Responderei o mais breve possível.
        </p>
    </div>
</section>

<!-- DIVISOR -->
<div class="contact-divider">
    <div class="container">
        <hr class="divider-line" />
    </div>
</div>

<!-- CONTEÚDO -->
<section class="contact-content">
    <div class="container">
        <div class="contact-grid">

            @if (messageSent)
            {
                <!-- SUCESSO -->
                <div class="contact-main">
                    <div class="success-block">
                        <div class="success-check">✓</div>
                        <p class="success-label">Mensagem enviada</p>
                        <h2 class="success-title">Obrigado pelo contato!</h2>
                        <p class="success-text">
                            Recebi sua mensagem e responderei em breve.
                        </p>
                        <button class="contact-submit-btn" @onclick="ResetForm">
                            Enviar outra mensagem
                        </button>
                    </div>
                </div>
            }
            else
            {
                <!-- FORMULÁRIO -->
                <div class="contact-main">
                    <EditForm Model="@formData" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />

                        <!-- Nome -->
                        <div class="field-group">
                            <label class="field-label">Nome</label>
                            <InputText class="field-input"
                                       @bind-Value="formData.Name"
                                       placeholder="Seu nome completo" />
                            <ValidationMessage For="@(() => formData.Name)"
                                               class="field-error" />
                        </div>

                        <!-- Email -->
                        <div class="field-group">
                            <label class="field-label">Email</label>
                            <InputText class="field-input"
                                       @bind-Value="formData.Email"
                                       placeholder="seu@email.com" />
                            <ValidationMessage For="@(() => formData.Email)"
                                               class="field-error" />
                        </div>

                        <!-- Tipo -->
                        <div class="field-group">
                            <label class="field-label">Tipo de contato</label>
                            <InputSelect class="field-select" @bind-Value="formData.Type">
                                <option value="0">Geral</option>
                                <option value="1">Oportunidade de emprego</option>
                                <option value="2">Freelance</option>
                                <option value="3">Parceria</option>
                                <option value="4">Outro</option>
                            </InputSelect>
                        </div>

                        <!-- Assunto -->
                        <div class="field-group">
                            <label class="field-label">Assunto</label>
                            <InputText class="field-input"
                                       @bind-Value="formData.Subject"
                                       placeholder="Sobre o que gostaria de falar?" />
                            <ValidationMessage For="@(() => formData.Subject)"
                                               class="field-error" />
                        </div>

                        <!-- Mensagem -->
                        <div class="field-group">
                            <label class="field-label">Mensagem</label>
                            <InputTextArea class="field-textarea"
                                           @bind-Value="formData.Message"
                                           placeholder="Escreva sua mensagem..."
                                           rows="7" />
                            <ValidationMessage For="@(() => formData.Message)"
                                               class="field-error" />
                        </div>

                        <!-- Erro -->
                        @if (hasError)
                        {
                            <div class="form-error-block">
                                Ocorreu um erro ao enviar. Tente novamente.
                            </div>
                        }

                        <!-- Botão -->
                        <div class="field-actions">
                            <button type="submit"
                                    class="contact-submit-btn @(isSending ? "sending" : "")"
                                    disabled="@isSending">
                                @if (isSending)
                                {
                                    <span>Enviando...</span>
                                }
                                else
                                {
                                    <span>Enviar mensagem →</span>
                                }
                            </button>
                        </div>

                    </EditForm>
                </div>

                <!-- SIDEBAR -->
                <aside class="contact-sidebar">

                    <div class="sidebar-block">
                        <p class="sidebar-label">Email direto</p>
                        <a href="mailto:contato@wpdev.com.br"
                           class="sidebar-email">
                            contato@wpdev.com.br
                        </a>
                    </div>

                    <div class="sidebar-block">
                        <p class="sidebar-label">Redes</p>
                        <div class="sidebar-links">
                            <a href="https://github.com/willdev34"
                               target="_blank"
                               class="sidebar-social-link">
                                GitHub ↗
                            </a>
                            <a href="https://www.linkedin.com/in/willdevfull/"
                               target="_blank"
                               class="sidebar-social-link">
                                LinkedIn ↗
                            </a>
                        </div>
                    </div>

                    <div class="sidebar-block sidebar-block--note">
                        <p class="sidebar-label">Tempo de resposta</p>
                        <p class="sidebar-note-text">
                            Costumo responder em até 48 horas nos dias úteis.
                        </p>
                    </div>

                </aside>
            }

        </div>
    </div>
</section>

@code {
    private SendContactMessageDto formData = new();
    private bool isSending = false;
    private bool messageSent = false;
    private bool hasError = false;

    private async Task HandleSubmit()
    {
        isSending = true;
        hasError = false;

        try
        {
            var success = await ContactService.SendMessageAsync(formData);

            if (success)
            {
                messageSent = true;
            }
            else
            {
                hasError = true;
            }
        }
        catch
        {
            hasError = true;
        }
        finally
        {
            isSending = false;
        }
    }

    private void ResetForm()
    {
        formData = new();
        messageSent = false;
        hasError = false;
    }
}