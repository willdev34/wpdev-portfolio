@page "/components-demo"
@using Portfolio.Web.Components.Shared

<PageTitle>Componentes - WPDev Portfolio</PageTitle>

<div class="demo-page">
    
    <header class="demo-header">
        <h1>Card Component - Demonstração</h1>
        <p>Visualização de todas as variantes e possibilidades do Card reutilizável</p>
    </header>

    <section class="demo-section">
        <h2 class="demo-section__title">1. Card Padrão</h2>
        <p class="demo-section__description">Layout vertical com imagem</p>
        
        <div class="demo-grid">
            
            <Card 
                ImageUrl="https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=800"
                ImageAlt="Código em tela de computador"
                Title="Sistema de Gerenciamento Completo"
                Description="Plataforma web moderna desenvolvida com .NET 8 e Blazor WebAssembly. Inclui autenticação JWT, CRUD completo e dashboard administrativo."
                Badge="Novo">
                
                <HeaderContent>
                    <div class="card-tags">
                        <span class="tag tag--primary">C#</span>
                        <span class="tag tag--secondary">Blazor</span>
                        <span class="tag tag--accent">PostgreSQL</span>
                    </div>
                </HeaderContent>
                
                <FooterContent>
                    <a href="#" class="card-link">Ver projeto completo</a>
                </FooterContent>
            </Card>

            <Card 
                Title="API REST em .NET Core"
                Description="API robusta seguindo Clean Architecture com CQRS e validação com FluentValidation.">
                
                <HeaderContent>
                    <span class="card-meta">Publicado em 15/12/2024</span>
                </HeaderContent>
                
                <FooterContent>
                    <a href="#" class="card-link">Documentação</a>
                </FooterContent>
            </Card>

            <Card 
                ImageUrl="https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=800"
                ImageAlt="Desenvolvimento de software"
                Title="Dashboard Analítico"
                Description="Interface interativa para visualização de dados em tempo real."
                Badge="Destaque">
                
                <HeaderContent>
                    <div class="card-tags">
                        <span class="tag tag--primary">React</span>
                        <span class="tag tag--secondary">TypeScript</span>
                    </div>
                </HeaderContent>
            </Card>
        </div>
    </section>

    <section class="demo-section">
        <h2 class="demo-section__title">2. Card Horizontal</h2>
        <p class="demo-section__description">Layout lado a lado</p>
        
        <div class="demo-stack">
            
            <Card 
                Variant="horizontal"
                ImageUrl="https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=800"
                ImageAlt="Workspace de desenvolvedor"
                Title="Como implementei Clean Architecture"
                Description="Tutorial completo mostrando a estrutura de pastas e separação de camadas.">
                
                <HeaderContent>
                    <div class="card-header-flex">
                        <span class="tag tag--accent">Tutorial</span>
                        <span class="card-meta">20 min de leitura</span>
                    </div>
                </HeaderContent>
                
                <FooterContent>
                    <div class="card-footer-flex">
                        <span class="card-meta">12 de Dezembro, 2024</span>
                        <a href="#" class="card-link">Ler artigo</a>
                    </div>
                </FooterContent>
            </Card>

            <Card 
                Variant="horizontal"
                Title="Migrando de Entity Framework 8 para 9"
                Description="Guia prático sobre a migração e novas features.">
                
                <HeaderContent>
                    <div class="card-header-flex">
                        <span class="tag tag--primary">Guia</span>
                        <span class="card-meta">8 min de leitura</span>
                    </div>
                </HeaderContent>
                
                <FooterContent>
                    <span class="card-meta">18 de Dezembro, 2024</span>
                </FooterContent>
            </Card>
        </div>
    </section>

    <section class="demo-section">
        <h2 class="demo-section__title">3. Card Minimal</h2>
        <p class="demo-section__description">Versão minimalista</p>
        
        <div class="demo-grid demo-grid--3col">
            
            <Card 
                Variant="minimal"
                Title="15+ Projetos"
                Description="Portfólio diversificado com aplicações web."
                Class="text-center">
            </Card>

            <Card 
                Variant="minimal"
                Title="5 Anos"
                Description="Experiência em desenvolvimento full-stack."
                Class="text-center">
            </Card>

            <Card 
                Variant="minimal"
                Title="100% Remoto"
                Description="Trabalho com equipes distribuídas."
                Class="text-center">
            </Card>
        </div>
    </section>

    <section class="demo-section">
        <h2 class="demo-section__title">5. Loading Skeletons</h2>
        <p class="demo-section__description">Placeholders animados durante carregamento</p>
        
        <div class="demo-grid">
            
            <div class="skeleton-demo-item">
                <h3 class="skeleton-demo-title">Card Skeleton</h3>
                <LoadingSkeleton Variant="card" />
            </div>

            <div class="skeleton-demo-item">
                <h3 class="skeleton-demo-title">Text Skeleton (5 linhas)</h3>
                <div style="background: white; padding: 20px; border-radius: 4px;">
                    <LoadingSkeleton Variant="text" Lines="5" />
                </div>
            </div>

            <div class="skeleton-demo-item">
                <h3 class="skeleton-demo-title">Circle Skeleton</h3>
                <div style="background: white; padding: 20px; border-radius: 4px;">
                    <LoadingSkeleton Variant="circle" Width="80px" Height="80px" />
                </div>
            </div>

            <div class="skeleton-demo-item">
                <h3 class="skeleton-demo-title">Rectangle Skeleton</h3>
                <div style="background: white; padding: 20px; border-radius: 4px;">
                    <LoadingSkeleton Variant="rectangle" Height="150px" />
                </div>
            </div>
        </div>

        <div class="demo-section" style="margin-top: 40px;">
            <h3 class="skeleton-demo-title">Grid de Card Skeletons (simulando carregamento de projetos)</h3>
            <div class="demo-grid">
                <LoadingSkeleton Variant="card" />
                <LoadingSkeleton Variant="card" />
                <LoadingSkeleton Variant="card" />
            </div>
        </div>
    </section>

    <section class="demo-section">
        <h2 class="demo-section__title">6. Button Component</h2>
        <p class="demo-section__description">Botões padronizados com múltiplas variantes e estados</p>
        
        <div class="demo-subsection">
            <h3 class="demo-subsection__title">Variantes</h3>
            <div class="button-demo-row">
                <Button Variant="primary">Primary</Button>
                <Button Variant="secondary">Secondary</Button>
                <Button Variant="outline">Outline</Button>
                <Button Variant="ghost">Ghost</Button>
                <Button Variant="danger">Danger</Button>
            </div>
        </div>

        <div class="demo-subsection">
            <h3 class="demo-subsection__title">Tamanhos</h3>
            <div class="button-demo-row">
                <Button Size="small">Small</Button>
                <Button Size="medium">Medium</Button>
                <Button Size="large">Large</Button>
            </div>
        </div>

        <div class="demo-subsection">
            <h3 class="demo-subsection__title">Com Ícones</h3>
            <div class="button-demo-row">
                <Button IconLeft="←">Voltar</Button>
                <Button IconRight="→">Próximo</Button>
                <Button IconLeft="📁" IconRight="✓">Salvar Arquivo</Button>
            </div>
        </div>

        <div class="demo-subsection">
            <h3 class="demo-subsection__title">Estados</h3>
            <div class="button-demo-row">
                <Button Disabled="true">Disabled</Button>
                <Button IsLoading="true" LoadingText="Carregando">Loading</Button>
                <Button IsLoading="true">Loading sem texto</Button>
            </div>
        </div>

        <div class="demo-subsection">
            <h3 class="demo-subsection__title">Como Links</h3>
            <div class="button-demo-row">
                <Button Href="/projetos">Ir para Projetos</Button>
                <Button Href="https://github.com" Target="_blank" IconRight="↗">GitHub</Button>
            </div>
        </div>
    </section>

</div>