@page "/projects"
@using Portfolio.Web.DTOs.Projects
@using Portfolio.Web.Services
@inject ProjectService ProjectService
@inject NavigationManager Navigation

<PageTitle>Projetos - WPDev Portfolio</PageTitle>

<div class="projects-page">
    <!-- Hero Section -->
    <section class="projects-hero">
        <h1 class="hero-title">Projetos</h1>
        <p class="hero-description">
            Uma coleção curada de trabalhos que refletem minha jornada como desenvolvedor,
            explorando diferentes tecnologias e soluções criativas.
        </p>
    </section>

    <!-- Search & Filters Section -->
    <section class="projects-controls">
        <div class="controls-wrapper">
            <!-- Search Bar -->
            <div class="search-container">
                <SearchBar 
                    @bind-Value="searchQuery"
                    Placeholder="Buscar projetos por nome ou descrição..."
                    OnSearch="HandleSearch" />
            </div>

            <!-- Filter Chips -->
            <div class="filters-container">
                <span class="filters-label">Tecnologias:</span>
                <div class="filters-chips">
                    @foreach (var tech in availableTechnologies)
                    {
                        <FilterChip 
                            Label="@tech"
                            IsActive="selectedTechnologies.Contains(tech)"
                            OnClick="() => ToggleTechnology(tech)" />
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Projects Grid -->
    <section class="projects-grid">
        @if (isLoading)
        {
            <!-- Loading Skeletons -->
            <div class="grid">
                @for (int i = 0; i < pageSize; i++)
                {
                    <LoadingSkeleton Variant="SkeletonVariant.Card" />
                }
            </div>
        }
        else if (filteredProjects == null || !filteredProjects.Any())
        {
            <!-- Empty State -->
            <div class="empty-state">
                <div class="empty-icon">🔍</div>
                <h3>Nenhum projeto encontrado</h3>
                <p>Tente ajustar os filtros ou realizar uma nova busca.</p>
                @if (!string.IsNullOrEmpty(searchQuery) || selectedTechnologies.Any())
                {
                    <Button 
                        Variant="ButtonVariant.Secondary"
                        OnClick="ClearFilters">
                        Limpar Filtros
                    </Button>
                }
            </div>
        }
        else
        {
            <!-- Projects Cards -->
            <div class="grid">
                @foreach (var project in paginatedProjects)
                {
                    <Card 
                        Title="@project.Title"
                        Description="@project.ShortDescription"
                        ImageUrl="@project.ImageUrl"
                        OnClick="() => NavigateToProject(project.Id)">
                        <HeaderContent>
                            @foreach (var tech in project.Technologies)
                            {
                                <span class="tech-tag">@tech</span>
                            }
                        </HeaderContent>
                    </Card>
                }
            </div>

            <!-- Pagination -->
            @if (totalPages > 1)
            {
                <div class="pagination-container">
                    <Pagination 
                        CurrentPage="currentPage"
                        TotalPages="totalPages"
                        OnPageChange="HandlePageChange" />
                </div>
            }
        }
    </section>
</div>

@code {
    // ============================================
    // STATE MANAGEMENT
    // ============================================
    
    // Data
    private List<ProjectCardDto> allProjects = new();
    private List<ProjectCardDto> filteredProjects = new();
    private List<ProjectCardDto> paginatedProjects = new();
    
    // Search & Filters
    private string searchQuery = string.Empty;
    private HashSet<string> selectedTechnologies = new();
    private List<string> availableTechnologies = new()
    {
        "C#", ".NET", "Blazor", "React", "Angular", 
        "Vue.js", "TypeScript", "JavaScript", "Python",
        "Docker", "Azure", "AWS", "PostgreSQL", "MongoDB"
    };
    
    // Pagination
    private int currentPage = 1;
    private int pageSize = 9; // 3x3 grid
    private int totalPages => (int)Math.Ceiling((double)filteredProjects.Count / pageSize);
    
    // UI State
    private bool isLoading = true;

    // ============================================
    // LIFECYCLE METHODS
    // ============================================
    
    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();
    }

    // ============================================
    // DATA LOADING
    // ============================================
    
    private async Task LoadProjects()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            // Buscar todos os projetos da API
            allProjects = await ProjectService.GetAllAsync();
            
            // Aplicar filtros
            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar projetos: {ex.Message}");
            allProjects = new List<ProjectCardDto>();
            filteredProjects = new List<ProjectCardDto>();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // ============================================
    // FILTERING & PAGINATION
    // ============================================
    
    private void ApplyFilters()
    {
        // Começar com todos os projetos
        var query = allProjects.AsEnumerable();

        // Aplicar busca por texto
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            var search = searchQuery.ToLower();
            query = query.Where(p => 
                p.Title.ToLower().Contains(search) || 
                (p.ShortDescription?.ToLower().Contains(search) ?? false)
            );
        }

        // Aplicar filtro por tecnologias (busca parcial, case-insensitive)
        if (selectedTechnologies.Any())
        {
            query = query.Where(p => 
                p.Technologies.Any(tech => 
                    selectedTechnologies.Any(selected => 
                        tech.Contains(selected, StringComparison.OrdinalIgnoreCase)
                    )
                )
            );
        }

        // Atualizar lista filtrada
        filteredProjects = query.ToList();

        // Aplicar paginação
        ApplyPagination();
    }

    private void ApplyPagination()
    {
        var skip = (currentPage - 1) * pageSize;
        paginatedProjects = filteredProjects
            .Skip(skip)
            .Take(pageSize)
            .ToList();
    }

    // ============================================
    // EVENT HANDLERS
    // ============================================
    
    private void HandleSearch()
    {
        // Reset para primeira página ao fazer nova busca
        currentPage = 1;
        ApplyFilters();
    }

    private void ToggleTechnology(string tech)
    {
        if (selectedTechnologies.Contains(tech))
        {
            selectedTechnologies.Remove(tech);
        }
        else
        {
            selectedTechnologies.Add(tech);
        }

        // Reset para primeira página ao alterar filtros
        currentPage = 1;
        ApplyFilters();
    }

    private void HandlePageChange(int newPage)
    {
        currentPage = newPage;
        ApplyPagination();
        StateHasChanged();
    }

    private void ClearFilters()
    {
        searchQuery = string.Empty;
        selectedTechnologies.Clear();
        currentPage = 1;
        ApplyFilters();
    }

    private void NavigateToProject(Guid projectId)
    {
        Navigation.NavigateTo($"/projects/{projectId}");
    }
}