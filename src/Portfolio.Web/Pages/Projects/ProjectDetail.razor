@* ====================================
   Título: ProjectDetail.razor
   Descrição: Página de detalhes de um projeto
   ==================================== *@

@page "/projects/{Id:guid}"
@using Portfolio.Web.Services
@using Portfolio.Web.DTOs.Projects
@using Portfolio.Web.Shared
@using Portfolio.Web.Components
@using Portfolio.Web.Helpers
@inject ProjectService ProjectService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<SeoHead Title="@($"{project?.Title ?? "Projeto"} - WPDev")"
         Description="@(project?.ShortDescription ?? project?.Description ?? "Detalhes do projeto desenvolvido por William, especialista em .NET e Blazor.")"
         ImageUrl="@project?.ImageUrl"
         OgType="article"
         Path="@($"/projects/{project?.Id}")" />

@if (isLoading)
{
    <div class="detail-loading">
        <LoadingSkeleton Lines="1" Height="520px" />
        <div class="container-narrow">
            <div class="loading-content">
                <LoadingSkeleton Lines="1" Width="60%" Height="48px" />
                <LoadingSkeleton Lines="4" />
                <LoadingSkeleton Lines="1" Width="30%" Height="24px" />
                <LoadingSkeleton Lines="1" Height="48px" />
            </div>
        </div>
    </div>
}
else if (project == null)
{
    <div class="detail-not-found">
        <p class="not-found-eyebrow">404</p>
        <h1 class="not-found-title">Projeto não encontrado</h1>
        <p class="not-found-text">O projeto que você procura não existe ou foi removido.</p>
        <a href="/projects" class="detail-back-btn">← Voltar para Projetos</a>
    </div>
}
else
{
    <!-- HERO -->
    <section class="project-hero">
        @if (!string.IsNullOrEmpty(project.ImageUrl))
        {
            <div class="hero-image">
                <img src="@CloudinaryUrlHelper.Optimize(project.ImageUrl, CloudinaryUrlHelper.HeroWidth)" 
                    alt="@project.Title" 
                    loading="eager" 
                    decoding="async"
                    width="1200"
                    height="630" />
            </div>
        }
        else
        {
            <div class="hero-image">
                <div class="hero-image--placeholder"></div>
            </div>
        }
        <div class="hero-overlay"></div>
        <div class="hero-overlay"></div>
        <button class="hero-zoom-btn" @onclick="OpenLightbox" title="Ver imagem em tela cheia">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/>
                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                <line x1="11" y1="8" x2="11" y2="14"/>
                <line x1="8" y1="11" x2="14" y2="11"/>
            </svg>
        </button>
        <div class="hero-content">
            <div class="container">
                <p class="hero-eyebrow">@project.Status</p>
                <h1 class="project-hero-title">@project.Title</h1>
                @if (!string.IsNullOrEmpty(project.ShortDescription))
                {
                    <p class="project-hero-description">@project.ShortDescription</p>
                }
            </div>
        </div>
    </section>

    <!-- CONTENT -->
    <section class="project-content scroll-reveal">
        <div class="container-narrow">
            <div class="content-grid">

                <!-- Coluna principal -->
                <div class="content-main">

                    @if (!string.IsNullOrEmpty(project.Description))
                    {
                        <div class="content-block">
                            <p class="block-eyebrow">Sobre o Projeto</p>
                            <div class="block-text">
                                <p>@project.Description</p>
                            </div>
                        </div>
                    }

                    @if (project.Technologies.Any())
                    {
                        <div class="content-block">
                            <p class="block-eyebrow">Stack Técnico</p>
                            <div class="tech-list">
                                @foreach (var tech in project.Technologies)
                                {
                                    <a href="/projects?tech=@Uri.EscapeDataString(tech)" class="tech-chip">@tech</a>
                                }
                            </div>
                        </div>
                    }

                </div>

                <!-- Sidebar -->
                <div class="content-sidebar">

                    <div class="sidebar-meta">
                        <div class="meta-item">
                            <span class="meta-label">Ano</span>
                            <span class="meta-value">@project.Year</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Status</span>
                            <span class="meta-value meta-value--accent">@project.Status</span>
                        </div>
                        @if (project.IsFeatured)
                        {
                            <div class="meta-item">
                                <span class="meta-label">Destaque</span>
                                <span class="meta-value meta-value--accent">Sim</span>
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(project.DemoUrl) || !string.IsNullOrEmpty(project.RepositoryUrl))
                    {
                        <div class="sidebar-actions">
                            @if (!string.IsNullOrEmpty(project.DemoUrl))
                            {
                                <a href="@project.DemoUrl" target="_blank" rel="noopener" class="detail-btn detail-btn--primary">
                                    Ver Demo →
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(project.RepositoryUrl))
                            {
                                <a href="@project.RepositoryUrl" target="_blank" rel="noopener" class="detail-btn detail-btn--ghost">
                                    Ver Código
                                </a>
                            }
                        </div>
                    }

                    <a href="/projects" class="back-link">← Todos os projetos</a>

                </div>

            </div>
        </div>
    </section>

    <!-- LIGHTBOX -->
    @if (_lightboxOpen)
    {
        <div class="lightbox-overlay" @onclick="CloseLightbox">
            <button class="lightbox-close" @onclick="CloseLightbox" @onclick:stopPropagation="true">✕</button>
            <img class="lightbox-img" 
                src="@CloudinaryUrlHelper.Optimize(project.ImageUrl, 1920)" 
                alt="@project.Title"
                @onclick:stopPropagation="true" />
        </div>
    }
}

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (project != null)
        {
            await JS.InvokeVoidAsync("setupScrollReveal");
        }
    }
    [Parameter]
    public Guid Id { get; set; }

    private ProjectDto? project;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadProject();
    }

    private async Task LoadProject()
    {
        isLoading = true;
        project = await ProjectService.GetByIdAsync(Id);
        isLoading = false;
    }
    private bool _lightboxOpen = false;

    private void OpenLightbox() => _lightboxOpen = true;
    private void CloseLightbox() => _lightboxOpen = false;
}