@* ====================================
   Título: Now.razor
   Descrição: Página "O que estou fazendo agora"
   Atualizado: campos alinhados com NowSectionDto real
   ==================================== *@

@page "/now"
@using Portfolio.Web.Services
@using Portfolio.Web.DTOs.Now
@using Portfolio.Web.Components
@inject NowService NowService
@inject IJSRuntime JS

<SeoHead Title="O que estou fazendo agora - WPDev"
         Description="Acompanhe o que William está estudando, desenvolvendo e priorizando no momento, no estilo nowpage."
         Path="/now" />

<!-- PAGE HEADER -->
<section class="now-header">
    <div class="container">
        <p class="now-eyebrow">Atualizado em tempo real</p>
        <h1 class="now-title">
            O que estou fazendo<br />
            <span class="now-title-accent">Agora</span>
        </h1>
        <p class="now-subtitle">
            Uma visão transparente do meu foco atual,
            aprendizados e objetivos profissionais.
        </p>
    </div>
</section>

<!-- DIVISOR -->
<div class="now-divider">
    <div class="container">
        <hr class="divider-line" />
    </div>
</div>

<!-- NOW CONTENT -->
<section class="now-content scroll-reveal">
    <div class="container">
        <div class="now-grid">

            @if (isLoading)
            {
                <div class="now-main">
                    <LoadingSkeleton Lines="1" Width="220px" Height="18px" />
                    <div style="margin-top: 3rem;">
                        <LoadingSkeleton Lines="1" Width="160px" Height="14px" />
                        <LoadingSkeleton Lines="3" />
                    </div>
                    <div style="margin-top: 3rem;">
                        <LoadingSkeleton Lines="1" Width="200px" Height="14px" />
                        <LoadingSkeleton Lines="4" />
                    </div>
                    <div style="margin-top: 3rem;">
                        <LoadingSkeleton Lines="1" Width="180px" Height="14px" />
                        <LoadingSkeleton Lines="3" />
                    </div>
                </div>
                <div class="now-sidebar">
                    <LoadingSkeleton Lines="1" Width="120px" Height="14px" />
                    <LoadingSkeleton Lines="2" />
                </div>
            }
            else if (nowSection != null)
            {
                <!-- COLUNA PRINCIPAL -->
                <div class="now-main">

                    <!-- Data de atualização -->
                    <p class="now-updated">
                        Última atualização:
                        <strong>@nowSection.UpdatedAt.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("pt-BR"))</strong>
                    </p>

                    <!-- Foco / Conteúdo principal -->
                    <div class="now-block">
                        <p class="now-block-label">Foco Atual</p>
                        <p class="now-block-text now-block-text--large">@nowSection.Content</p>
                    </div>

                    <!-- Projetos atuais -->
                    @if (nowSection.CurrentProjects.Any())
                    {
                        <div class="now-block">
                            <p class="now-block-label">Projetos em Andamento</p>
                            @foreach (var project in nowSection.CurrentProjects)
                            {
                                <p class="now-block-text now-block-text--large">
                                    @if (!string.IsNullOrEmpty(project.Url))
                                    {
                                        <a href="@project.Url"
                                        target="_blank"
                                        class="now-project-link">
                                            @project.Name
                                            <span class="now-project-arrow">↗</span>
                                        </a>
                                    }
                                    else
                                    {
                                        @project.Name
                                    }
                                </p>
                            }
                        </div>
                    }

                    <!-- Aprendendo Agora -->
                    @if (nowSection.CurrentlyLearning.Any())
                    {
                        <div class="now-block">
                            <p class="now-block-label">Aprendendo Agora</p>
                            <ul class="now-list">
                                @foreach (var item in nowSection.CurrentlyLearning)
                                {
                                    <li class="now-list-item">
                                        <span class="now-list-arrow">→</span>
                                        <span>@item</span>
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                    <!-- Objetivos -->
                    @if (nowSection.CurrentGoals.Any())
                    {
                        <div class="now-block">
                            <p class="now-block-label">Objetivos Atuais</p>
                            <ul class="now-list now-list--goals">
                                @foreach (var goal in nowSection.CurrentGoals)
                                {
                                    <li class="now-list-item now-list-item--goal">
                                        <span class="now-list-check">✓</span>
                                        <span>@goal</span>
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                </div>

                <!-- SIDEBAR -->
                <aside class="now-sidebar">

                    <!-- Inspiração -->
                    <div class="sidebar-block sidebar-block--inspiration">
                        <p class="sidebar-label">Sobre esta página</p>
                        <p class="sidebar-inspiration-text">
                            Inspirado pelo movimento
                            <a href="https://nownownow.com"
                               target="_blank"
                               class="sidebar-link">
                                nownownow.com
                            </a>,
                            onde pessoas compartilham o que estão fazendo agora.
                        </p>
                    </div>

                </aside>
            }
            else
            {
                <!-- EMPTY STATE -->
                <div class="now-empty">
                    <p class="now-empty-title">Em construção</p>
                    <p class="now-empty-text">Esta seção estará disponível em breve.</p>
                </div>
            }

        </div>
    </div>
</section>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (nowSection != null)
        {
            await JS.InvokeVoidAsync("setupScrollReveal");
        }
    }
    private NowSectionDto? nowSection;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadNow();
    }

    private async Task LoadNow()
    {
        isLoading = true;
        nowSection = await NowService.GetCurrentAsync();
        isLoading = false;
    }
}