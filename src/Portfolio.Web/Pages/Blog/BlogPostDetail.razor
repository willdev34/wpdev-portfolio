@* ====================================
   Título: BlogPostDetail.razor
   Descrição: Página de detalhes de um post do blog
   ==================================== *@

@page "/blog/{Id:guid}"
@using Portfolio.Web.Services
@using Portfolio.Web.DTOs.BlogPosts
@using Portfolio.Web.Components
@using Markdig
@using Portfolio.Web.Helpers
@inject BlogPostService BlogPostService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<SeoHead Title="@($"{post?.Title ?? "Post"} - WPDev")"
         Description="@(post?.Excerpt ?? "Artigo técnico sobre desenvolvimento de software por William.")"
         ImageUrl="@post?.FeaturedImageUrl"
         OgType="article"
         Path="@($"/blog/{post?.Id}")" />

@if (isLoading)
{
    <div class="detail-loading">
        <LoadingSkeleton Lines="1" Height="420px" />
        <div class="container-narrow">
            <div class="loading-content">
                <LoadingSkeleton Lines="1" Width="80%" Height="48px" />
                <LoadingSkeleton Lines="1" Width="40%" Height="24px" />
                <LoadingSkeleton Lines="6" />
                <LoadingSkeleton Lines="4" />
            </div>
        </div>
    </div>
}
else if (post == null)
{
    <div class="detail-not-found">
        <p class="not-found-eyebrow">404</p>
        <h1 class="not-found-title">Post não encontrado</h1>
        <p class="not-found-text">O artigo que você procura não existe ou foi removido.</p>
        <a href="/blog" class="detail-back-btn">← Voltar para o Blog</a>
    </div>
}
else
{
    <!-- HERO -->
    <section class="post-hero">
        @if (!string.IsNullOrEmpty(post.FeaturedImageUrl))
        {
            <div class="hero-image">
                <img src="@CloudinaryUrlHelper.Optimize(post.FeaturedImageUrl, CloudinaryUrlHelper.HeroWidth)" 
                     alt="@post.Title" 
                     loading="eager" 
                     decoding="async"
                     width="1200"
                     height="630" />
            </div>
        }
        else
        {
            <div class="hero-image">
                <div class="hero-image--placeholder"></div>
            </div>
        }
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="container-narrow">
                <div class="post-meta">
                    <time>@post.PublishedAt.ToString("dd MMM yyyy")</time>
                    <span class="meta-separator">•</span>
                    <span class="post-reading">@post.ReadTimeMinutes min de leitura</span>
                </div>
                <h1 class="post-hero-title">@post.Title</h1>
                @if (post.Tags.Any())
                {
                    <div class="post-tags">
                        @foreach (var tag in post.Tags)
                        {
                            <span class="tag-badge">#@tag</span>
                        }
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- CONTENT -->
    <section class="post-content scroll-reveal">
        <div class="container-narrow">

            @if (!string.IsNullOrEmpty(post.Excerpt))
            {
                <div class="post-excerpt">
                    <p class="excerpt-text">@post.Excerpt</p>
                </div>
            }

            @if (!string.IsNullOrEmpty(post.Content))
            {
                <div class="article-body">
                    @((MarkupString)renderedContent)
                </div>
            }

            @if (post.Tags.Any())
            {
                <div class="article-footer">
                    <span class="footer-label">Tags</span>
                    @foreach (var tag in post.Tags)
                    {
                        <span class="footer-tag">#@tag</span>
                    }
                </div>
            }

            <a href="/blog" class="back-link">← Voltar para o Blog</a>

        </div>
    </section>
}

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (post != null)
        {
            await JS.InvokeVoidAsync("setupScrollReveal");
        }
    }
    [Parameter]
    public Guid Id { get; set; }

    private BlogPostDto? post;
    private bool isLoading = true;
    private string renderedContent = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadPost();
    }

    private async Task LoadPost()
    {
        isLoading = true;
        post = await BlogPostService.GetByIdAsync(Id);

        if (post != null && !string.IsNullOrEmpty(post.Content))
        {
            var pipeline = new MarkdownPipelineBuilder()
                .UseAdvancedExtensions()
                .Build();
            renderedContent = Markdown.ToHtml(post.Content, pipeline);
        }

        isLoading = false;
    }
}