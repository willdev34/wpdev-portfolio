@* ====================================
   Título: Blog.razor
   Descrição: Página de listagem de posts do blog
   Autor: Will
   Empresa: WpDev
   Data: 20/12/2024
   ==================================== *@

@page "/blog"
@using Portfolio.Web.DTOs.BlogPosts
@using Portfolio.Web.Services
@inject BlogPostService BlogPostService
@inject NavigationManager Navigation

<PageTitle>Blog - WPDev Portfolio</PageTitle>

<div class="blog-page">

    <!-- Hero Section -->
    <section class="blog-hero">
        <h1 class="hero-title">Blog</h1>
        <p class="hero-description">
            Reflexões sobre desenvolvimento, arquitetura de software
            e tendências em tecnologia.
        </p>
    </section>

    <!-- Controls Section -->
    <section class="blog-controls">
        <div class="controls-wrapper">

            <!-- Search Bar -->
            <div class="search-container">
                <SearchBar
                    @bind-Value="searchQuery"
                    Placeholder="Buscar posts por título ou conteúdo..."
                    OnSearch="HandleSearch" />
            </div>

            <!-- Filter Chips por Tag -->
            <div class="filters-container">
                <span class="filters-label">Tags:</span>
                <div class="filters-chips">
                    @foreach (var tag in availableTags)
                    {
                        <FilterChip
                            Label="@tag"
                            IsActive="selectedTags.Contains(tag)"
                            OnClick="() => ToggleTag(tag)" />
                    }
                </div>
            </div>

        </div>
    </section>

    <!-- Blog Posts Grid -->
    <section class="blog-content-section">

        @if (isLoading)
        {
            <div class="blog-grid">
                @for (int i = 0; i < pageSize; i++)
                {
                    <LoadingSkeleton Variant="SkeletonVariant.Card" />
                }
            </div>
        }
        else if (filteredPosts == null || !filteredPosts.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">✍️</div>
                <h3>Nenhum post encontrado</h3>
                <p>Tente ajustar os filtros ou realizar uma nova busca.</p>
                @if (!string.IsNullOrEmpty(searchQuery) || selectedTags.Any())
                {
                    <Button
                        Variant="ButtonVariant.Secondary"
                        OnClick="ClearFilters">
                        Limpar Filtros
                    </Button>
                }
            </div>
        }
        else
        {
            <div class="blog-grid">
                @foreach (var post in paginatedPosts)
                {
                    <Card
                        Title="@post.Title"
                        Description="@post.Excerpt"
                        OnClick="() => NavigateToPost(post.Id)">
                        <HeaderContent>
                            <div class="blog-meta-info">
                                <time class="blog-date">
                                    @post.PublishedAt.ToString("dd MMM yyyy")
                                </time>
                                <span class="blog-reading">
                                    @post.ReadTimeMinutes min de leitura
                                </span>
                            </div>
                        </HeaderContent>
                        <FooterContent>
                            <div class="blog-tags">
                                @foreach (var tag in post.Tags.Take(3))
                                {
                                    <span class="tag-pill">#@tag</span>
                                }
                            </div>
                        </FooterContent>
                    </Card>
                }
            </div>

            @if (totalPages > 1)
            {
                <div class="pagination-container">
                    <Pagination
                        CurrentPage="currentPage"
                        TotalPages="totalPages"
                        OnPageChange="HandlePageChange" />
                </div>
            }
        }

    </section>

</div>

@code {
    // ============================================
    // STATE
    // ============================================

    private List<BlogPostCardDto> allPosts = new();
    private List<BlogPostCardDto> filteredPosts = new();
    private List<BlogPostCardDto> paginatedPosts = new();

    // Search & Filters
    private string searchQuery = string.Empty;
    private HashSet<string> selectedTags = new();
    private List<string> availableTags = new()
    {
        "C#", ".NET", "Blazor", "React", "Angular",
        "TypeScript", "JavaScript", "Python",
        "Docker", "Azure", "Clean Architecture", "CQRS"
    };

    // Pagination
    private int currentPage = 1;
    private int pageSize = 6;
    private int totalPages => (int)Math.Ceiling((double)filteredPosts.Count / pageSize);

    // UI
    private bool isLoading = true;

    // ============================================
    // LIFECYCLE
    // ============================================

    protected override async Task OnInitializedAsync()
    {
        await LoadPosts();
    }

    // ============================================
    // DATA
    // ============================================

    private async Task LoadPosts()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            allPosts = await BlogPostService.GetAllAsync();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar posts: {ex.Message}");
            allPosts = new List<BlogPostCardDto>();
            filteredPosts = new List<BlogPostCardDto>();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // ============================================
    // FILTERS & PAGINATION
    // ============================================

    private void ApplyFilters()
    {
        var query = allPosts.AsEnumerable();

        // Busca por texto
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            var search = searchQuery.ToLower();
            query = query.Where(p =>
                p.Title.ToLower().Contains(search) ||
                p.Excerpt.ToLower().Contains(search)
            );
        }

        // Filtro por tags (busca parcial)
        if (selectedTags.Any())
        {
            query = query.Where(p =>
                p.Tags.Any(tag =>
                    selectedTags.Any(selected =>
                        tag.Contains(selected, StringComparison.OrdinalIgnoreCase)
                    )
                )
            );
        }

        filteredPosts = query.ToList();
        ApplyPagination();
    }

    private void ApplyPagination()
    {
        paginatedPosts = filteredPosts
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    // ============================================
    // EVENTS
    // ============================================

    private void HandleSearch()
    {
        currentPage = 1;
        ApplyFilters();
    }

    private void ToggleTag(string tag)
    {
        if (selectedTags.Contains(tag))
            selectedTags.Remove(tag);
        else
            selectedTags.Add(tag);

        currentPage = 1;
        ApplyFilters();
    }

    private void HandlePageChange(int newPage)
    {
        currentPage = newPage;
        ApplyPagination();
        StateHasChanged();
    }

    private void ClearFilters()
    {
        searchQuery = string.Empty;
        selectedTags.Clear();
        currentPage = 1;
        ApplyFilters();
    }

    private void NavigateToPost(Guid postId)
    {
        Navigation.NavigateTo($"/blog/{postId}");
    }
}