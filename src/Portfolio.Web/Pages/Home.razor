@* ====================================
   Título: Home.razor
   Descrição: Página inicial editorial WPDev
   Refatorada: design editorial, componentes,
               estilos movidos para Home.razor.css
   ==================================== *@

@page "/"
@using Portfolio.Web.Services
@using Portfolio.Web.DTOs.Projects
@using Portfolio.Web.Components
@using Portfolio.Web.Helpers
@inject ProjectService ProjectService
@inject IJSRuntime JS

<SeoHead Title="WPDev - Portfólio de William, Desenvolvedor Full Stack"
         Description="Portfólio de William, desenvolvedor Full Stack especializado em .NET, Blazor WebAssembly e arquitetura de software. Projetos, blog técnico e timeline de carreira."
         Path="/" />

<!-- ================================
     HERO
     ================================ -->
<section class="home-hero">
    <img id="hero-poster" 
        class="hero-bg-poster" 
        src="/images/hero-poster.webp" 
        alt="" 
        aria-hidden="true"
        fetchpriority="high"
        decoding="async"
        width="1280"
        height="720" />
    <video id="hero-video" class="hero-bg-video" autoplay muted loop playsinline preload="none">
        <source id="hero-video-source" src="" type="video/mp4" />
        <track kind="captions" srclang="pt" label="Português" default />
    </video>
    <div class="hero-overlay"></div>
    <div class="container">
        <div class="hero-inner">

            <div class="hero-text">
                <p class="hero-eyebrow">Desenvolvedor Full Stack</p>
                <h1 class="hero-title">
                    Construindo<br />
                    software que<br />
                    <span class="hero-title-accent">importa<span class="hero-cursor">.</span><span class="hero-cursor-blink">|</span></span>
                </h1>
            </div>

            <div class="hero-desc">
                <p class="hero-subtitle">
                    Portfólio de projetos com foco em arquitetura limpa,
                    código de qualidade e experiência de usuário bem pensada.
                </p>
                <div class="hero-actions">
                    <a href="/projects" class="home-btn home-btn--primary">
                        Ver projetos
                    </a>
                    <a href="/contact" class="home-btn home-btn--ghost">
                        Entrar em contato
                    </a>
                </div>
            </div>

        </div>
    </div>

    <!-- Linha decorativa no rodapé do hero -->
    <div class="hero-bottom-line">
        <div class="container">
            <hr class="hero-divider" />
        </div>
    </div>
</section>

<!-- ================================
     PROJETOS EM DESTAQUE
     ================================ -->
<section class="home-section scroll-reveal">
    <div class="container">

        <div class="section-header">
            <p class="section-eyebrow">Trabalhos recentes</p>
            <h2 class="section-title">Projetos em destaque</h2>
        </div>

        @if (isLoading)
        {
            <div class="featured-grid">
                <div class="featured-item featured-item--large">
                    <LoadingSkeleton Lines="1" Height="320px" />
                    <div style="margin-top:1.5rem">
                        <LoadingSkeleton Lines="1" Width="60%" Height="28px" />
                        <LoadingSkeleton Lines="2" />
                    </div>
                </div>
                <div class="featured-stack">
                    <div class="featured-item">
                        <LoadingSkeleton Lines="1" Height="180px" />
                        <div style="margin-top:1rem">
                            <LoadingSkeleton Lines="1" Width="70%" Height="22px" />
                            <LoadingSkeleton Lines="1" />
                        </div>
                    </div>
                    <div class="featured-item">
                        <LoadingSkeleton Lines="1" Height="180px" />
                        <div style="margin-top:1rem">
                            <LoadingSkeleton Lines="1" Width="70%" Height="22px" />
                            <LoadingSkeleton Lines="1" />
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (projects.Any())
        {
            <div class="featured-grid">

                <!-- Projeto principal: maior -->
                <a href="/projects/@projects[0].Id" class="featured-item featured-item--large">
                    <div class="featured-thumb">
                        @if (!string.IsNullOrEmpty(projects[0].ImageUrl))
                        {
                            <img src="@CloudinaryUrlHelper.Optimize(projects[0].ImageUrl, CloudinaryUrlHelper.HeroWidth)" alt="@projects[0].Title" loading="eager" decoding="async" />
                        }
                        else
                        {
                            <div class="featured-thumb-placeholder"></div>
                        }
                    </div>
                    <div class="featured-info">
                        <div class="featured-tech-row">
                            @foreach (var tech in projects[0].Technologies.Take(3))
                            {
                                <a href="/projects?tech=@Uri.EscapeDataString(tech)" class="featured-tech" @onclick:stopPropagation="true">@tech</a>
                            }
                        </div>
                        <h3 class="featured-title">@projects[0].Title</h3>
                        <p class="featured-desc">@projects[0].ShortDescription</p>
                    </div>
                </a>

                <!-- Projetos secundários: stack vertical -->
                <div class="featured-stack">
                    @foreach (var project in projects.Skip(1).Take(2))
                    {
                        <a href="/projects/@project.Id" class="featured-item">
                            <div class="featured-thumb featured-thumb--small">
                                @if (!string.IsNullOrEmpty(project.ImageUrl))
                                {
                                    <img src="@CloudinaryUrlHelper.Optimize(project.ImageUrl, CloudinaryUrlHelper.ThumbnailWidth)" alt="@project.Title" loading="lazy" decoding="async" />
                                }
                                else
                                {
                                    <div class="featured-thumb-placeholder"></div>
                                }
                            </div>
                            <div class="featured-info">
                                <div class="featured-tech-row">
                                    @foreach (var tech in project.Technologies.Take(2))
                                    {
                                        <a href="/projects?tech=@Uri.EscapeDataString(tech)" class="featured-tech" @onclick:stopPropagation="true">@tech</a>
                                    }
                                </div>
                                <h3 class="featured-title featured-title--small">@project.Title</h3>
                                <p class="featured-desc featured-desc--small">@project.ShortDescription</p>
                            </div>
                        </a>
                    }
                </div>

            </div>

            <div class="section-cta">
                <a href="/projects" class="home-btn home-btn--ghost">
                    Ver todos os projetos →
                </a>
            </div>
        }
        else
        {
            <div class="home-empty">
                <p>Nenhum projeto em destaque ainda.</p>
            </div>
        }

    </div>
</section>

<!-- ================================
     SKILLS / TECNOLOGIAS
     ================================ -->
<section class="home-section home-section--dark scroll-reveal">
    <div class="container">

        <div class="section-header section-header--light">
            <p class="section-eyebrow section-eyebrow--light">Stack técnico</p>
            <h2 class="section-title section-title--light">Tecnologias que uso</h2>
        </div>

        <div class="skills-grid">
            <div class="skill-group">
                <p class="skill-group-label">Backend</p>
                <ul class="skill-list">
                    <li>Python / FastAPI / Django</li>
                    <li>.NET 8 / ASP.NET Core / C#</li>
                    <li>Java / Spring Boot</li>
                    <li>PHP / Laravel / CodeIgniter</li>
                    <li>CQRS / MediatR / Clean Architecture</li>
                </ul>
            </div>

            <div class="skill-group">
                <p class="skill-group-label">Frontend</p>
                <ul class="skill-list">
                    <li>React / TypeScript</li>
                    <li>Blazor WebAssembly</li>
                    <li>Angular</li>
                    <li>HTML / CSS / JavaScript</li>
                    <li>Tailwind CSS</li>
                </ul>
            </div>

            <div class="skill-group">
                <p class="skill-group-label">Banco de Dados</p>
                <ul class="skill-list">
                    <li>PostgreSQL</li>
                    <li>SQL Server / T-SQL</li>
                    <li>MySQL</li>
                    <li>Oracle / PL-SQL</li>
                    <li>MongoDB</li>
                </ul>
            </div>

            <div class="skill-group">
                <p class="skill-group-label">Infraestrutura</p>
                <ul class="skill-list">
                    <li>Docker / Docker Compose</li>
                    <li>GitHub Actions / CI-CD</li>
                    <li>Azure / Render</li>
                    <li>Git / GitFlow</li>
                    <li>Testes unitários e integração</li>
                </ul>
            </div>

            <div class="skill-group">
                <p class="skill-group-label">CMS e Outros</p>
                <ul class="skill-list">
                    <li>WordPress / WooCommerce</li>
                    <li>Moodle</li>
                    <li>Unity 5 (C#)</li>
                </ul>
            </div>
        </div>

    </div>
</section>

<!-- ================================
     CTA CONTATO
     ================================ -->
<section class="home-cta scroll-reveal">
    <div class="container">
        <div class="cta-inner">
            <p class="cta-eyebrow">Disponível para projetos</p>
            <h2 class="cta-title">Tem um projeto em mente?</h2>
            <p class="cta-text">
                Estou aberto a conversas sobre oportunidades, freelas e parcerias.
            </p>
            <a href="/contact" class="home-btn home-btn--primary">
                Entrar em contato
            </a>
        </div>
    </div>
</section>

@code {
    private List<ProjectCardDto> projects = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();
    }

    private async Task LoadProjects()
    {
        isLoading = true;
        projects = await ProjectService.GetFeaturedAsync();
        isLoading = false;
    }

    private bool _scrollRevealInitialized = false;
    private bool _videoLoaded = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Carrega o vídeo só depois que a página renderizar
        if (firstRender && !_videoLoaded)
        {
            _videoLoaded = true;
            await JS.InvokeVoidAsync("loadHeroVideo",
                "hero-video-source",
                "https://res.cloudinary.com/do0uq7w4n/video/upload/q_auto,f_auto/v1782685612/hero-code-optimized_oun8qf.mp4");
        }

        if (!_scrollRevealInitialized && projects != null && projects.Count > 0)
        {
            _scrollRevealInitialized = true;
            await JS.InvokeVoidAsync("setupScrollReveal");
        }
    }
}