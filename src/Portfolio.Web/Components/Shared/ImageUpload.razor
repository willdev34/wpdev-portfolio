@* ====================================
   Título: ImageUpload.razor
   Descrição: Upload de imagem via Cloudinary com callback direto para Blazor
   ==================================== *@

@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="image-upload">
    @if (!string.IsNullOrEmpty(_previewUrl))
    {
        <div class="image-preview">
            <img src="@_previewUrl" alt="Preview" />
            <button type="button" class="image-preview__remove" @onclick="RemoveImage">×</button>
        </div>
    }

    <div class="image-upload__area">
        @if (_isUploading)
        {
            <div class="upload-progress">
                <div class="upload-spinner"></div>
                <span>Enviando...</span>
            </div>
        }
        else
        {
            <label class="upload-label" for="file-input-@_id">
                <span class="upload-icon">↑</span>
                <span class="upload-text">Clique ou arraste uma imagem</span>
                <span class="upload-hint">PNG, JPG, WebP até 10MB</span>
            </label>
            <input id="file-input-@_id"
                   type="file"
                   accept="image/*"
                   class="upload-input" />
            <img id="preview-@_id"
                 style="display:none;width:100%;height:160px;object-fit:cover;border-radius:8px;margin-bottom:8px;"
                 alt="" />
        }
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <p class="upload-error">@_errorMessage</p>
    }

    <div class="upload-url-row">
        <span class="upload-url-label">ou cole a URL</span>
        <input class="field__input upload-url-input"
               type="url"
               placeholder="https://..."
               value="@CurrentUrl"
               @oninput="HandleUrlInput" />
    </div>
</div>

@code {
    [Parameter] public string? CurrentUrl { get; set; }
    [Parameter] public EventCallback<string> OnUrlChanged { get; set; }

    private const string CloudName = "do0uq7w4n";
    private const string UploadPreset = "wpdev_portfolio";

    private string _id = Guid.NewGuid().ToString("N")[..8];
    private string _errorMessage = string.Empty;
    private string _previewUrl = string.Empty;
    private bool _isUploading = false;
    private DotNetObjectReference<ImageUpload>? _dotNetRef;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(CurrentUrl) && string.IsNullOrEmpty(_previewUrl))
            _previewUrl = CurrentUrl;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("setupImageUpload",
                $"file-input-{_id}",
                $"preview-{_id}",
                _dotNetRef,
                CloudName,
                UploadPreset);
        }
    }

    [JSInvokable]
    public async Task OnImageUploaded(string url)
    {
        CurrentUrl = url;
        _previewUrl = url;
        _isUploading = false;
        await JS.InvokeVoidAsync("eval", $"var el=document.getElementById('preview-{_id}');if(el)el.style.display='none'");
        await OnUrlChanged.InvokeAsync(url);
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleUrlInput(ChangeEventArgs e)
    {
        var url = e.Value?.ToString() ?? string.Empty;
        CurrentUrl = url;
        _previewUrl = url;
        await OnUrlChanged.InvokeAsync(url);
    }

    private async Task RemoveImage()
    {
        CurrentUrl = string.Empty;
        _previewUrl = string.Empty;
        await OnUrlChanged.InvokeAsync(string.Empty);
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        await Task.CompletedTask;
    }
}